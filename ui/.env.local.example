# Copy this file to .env.local and fill in values from your TechZone reservation.
# .env.local is gitignored — never commit real credentials.

# AIX Client (pvm3) — the certificate target
AIX_HOST=p<NNNN>-pvm3.p<NNNN>.cecc.ihost.com
AIX_USER=cecuser
# Path to the private SSH key downloaded from TechZone reservation details
AIX_SSH_KEY_PATH=/home/cecuser/.ssh/techzone-key.pem

# Vault — running on this same RHEL host (pvm2) via Podman
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=myroot

# PowerSC UI URL (pvm1) — used to generate the direct link in the UI
POWERSC_URL=https://p<NNNN>-pvm1.p<NNNN>.cecc.ihost.com

# Backend server port (Express + WebSocket)
API_PORT=3002
