# Copy this file to .env.local and fill in values from your TechZone reservation.
# .env.local is gitignored — never commit real credentials.

# AIX Client (pvm3) — the certificate target
AIX_HOST=p<NNNN>-pvm3.p<NNNN>.cecc.ihost.com
AIX_USER=cecuser
# Path to the private SSH key downloaded from TechZone reservation details
AIX_SSH_KEY_PATH=/home/cecuser/.ssh/techzone-key.pem

# Vault — running on this same RHEL host (pvm2) via Podman
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=myroot

# PowerSC (pvm1)
# POWERSC_URL is used for the direct link in the UI AND as the base URL for API scan calls.
# POWERSC_USER / POWERSC_PASS — credentials from TechZone reservation details.
# AIX_HOSTNAME — short hostname of pvm3 as it appears in the PowerSC Endpoints list
#   (typically the bare hostname without domain, e.g. "p1294-pvm3").
# NOTE: If POWERSC_PASS is left blank, scan buttons will show a manual-trigger fallback
#   instructing the presenter to use the PowerSC UI directly — that path always works.
POWERSC_URL=https://p<NNNN>-pvm1.p<NNNN>.cecc.ihost.com
POWERSC_USER=powersc-admin
POWERSC_PASS=
AIX_HOSTNAME=p<NNNN>-pvm3

# Backend server port (Express + WebSocket)
API_PORT=3002
